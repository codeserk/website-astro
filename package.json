{
  "name": "website-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "lint": "eslint --ext .ts,.tsx,.md,.mdx,.astro src",
    "lint:fix": "eslint --fix src",
    "dev": "astro dev",
    "dev:host": "astro dev --host",
    "cypress": "cypress open",
    "cypress:headless": "cypress run",
    "e2e": "start-server-and-test preview http://127.0.0.1:4321 cypress:headless",
    "e2e:dev": "npm run build && start-server-and-test preview http://127.0.0.1:4321 cypress:headless",
    "start": "astro dev",
    "build": "astro build",
    "test:e2e": "playwright test",
    "screenshot:rocket": "playwright test e2e/screenshot-rocket.spec.ts --project=webkit",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "@codeserk/forge-stats": "^0.0.1",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "astro": "^5.15.1",
    "astro-remote": "^0.3.4",
    "dayjs": "^1.11.20",
    "postprocessing": "^6.36.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-accessible-emojis": "^0.3.2",
    "remark": "^15.0.1",
    "remark-gemoji": "^8.0.0",
    "remark-toc": "^9.0.0",
    "sharp": "^0.33.5",
    "strip-markdown": "^6.0.0",
    "swiper": "^12.1.3",
    "tailwindcss": "^3.4.19",
    "three": "^0.160.0",
    "three-stdlib": "^2.36.1",
    "typed.js": "^2.1.0",
    "uuid": "^10.0.0",
    "vite-plugin-glsl": "^1.3.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@playwright/test": "1.59.1",
    "@types/three": "0.160.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cypress": "^13.17.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-cypress": "^3.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^6.6.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "remark-frontmatter": "^5.0.0",
    "remark-lint": "^10.0.1",
    "remark-lint-first-heading-level": "^4.0.1",
    "remark-parse-frontmatter": "^1.0.3",
    "remark-preset-lint-consistent": "^6.0.1",
